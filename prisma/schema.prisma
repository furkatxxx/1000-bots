generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Источники трендов (Hacker News, Google Trends, NewsAPI и др.)
model TrendSource {
  id        String   @id @default(cuid())
  name      String   @unique // "hacker_news", "google_trends", "news_api"
  label     String           // "Hacker News", "Google Trends", "NewsAPI"
  enabled   Boolean  @default(true)
  config    String?          // JSON: дополнительные настройки
  lastRunAt DateTime?
  createdAt DateTime @default(now())
}

// Собранные тренды из источников
model TrendData {
  id        String   @id @default(cuid())
  sourceId  String           // Ссылка на TrendSource.name
  title     String           // Заголовок тренда
  url       String?          // Ссылка на источник
  score     Int      @default(0) // Очки популярности (0-100)
  summary   String?          // Краткое описание
  category  String?          // Категория: "tech", "business", "ai"
  metadata  String?          // JSON: доп. данные из источника
  fetchedAt DateTime @default(now())

  @@index([sourceId, fetchedAt])
}

// Ежедневные отчёты
model DailyReport {
  id          String    @id @default(cuid())
  date        DateTime  @unique // Одна дата = один отчёт
  status      String    @default("pending") // pending, generating, complete, failed
  trendsCount Int       @default(0)
  ideasCount  Int       @default(0)
  aiModel     String?
  aiTokensIn  Int?
  aiTokensOut Int?
  error       String?   // Ошибка, если статус failed
  generatedAt DateTime?
  createdAt   DateTime  @default(now())
  // Pipeline: промежуточные данные между этапами
  pipelineStage       String?   // "stage-1" | "stage-2" | "stage-3" | null (готово)
  trendAnalysis       String?   // Результат analyzeTrends от Opus (нужен для generateIdeas)
  filteredTrendsJson  String?   // JSON: тренды после фильтра (нужны для generateIdeas)

  ideas BusinessIdea[]
}

// Бизнес-идеи, сгенерированные AI
model BusinessIdea {
  id               String      @id @default(cuid())
  reportId         String
  report           DailyReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  name             String
  emoji            String      @default("💡")
  description      String
  targetAudience   String      // Целевая аудитория
  monetization     String      // Как зарабатывать
  startupCost      String      // "low", "medium", "high" + описание
  competitionLevel String      // "low", "medium", "high"
  trendBacking     String      // Какие тренды подтверждают идею
  actionPlan       String      // Пошаговый план
  claudeCodeReady  Boolean     @default(false) // Можно реализовать через Claude Code?
  difficulty       String      @default("medium") // easy, medium, hard
  successChance    Int?        // Шанс успеха 1-100 (оценка AI)
  estimatedRevenue String?     // Ожидаемый доход за 3 месяца
  timeToLaunch     String?     // Время до запуска (например "14 дней")
  market           String      @default("both") // "russia" | "global" | "both"
  marketScenarios  String?     // JSON: сценарии развития для России и мирового рынка
  deepDive         String?     // Развёрнутый план реализации (markdown)
  expertAnalysis   String?     // JSON: анализ от экспертного совета (4 специалиста)
  analogs          String?     // JSON: найденные аналоги на Product Hunt и GitHub (#32)
  landingHtml      String?     // HTML лендинга для проверки спроса (#33)
  marketAnalysis   String?     // JSON: TAM/SAM/SOM + SEO-анализ (#34, #35)
  adCopy           String?     // JSON: тексты для рекламы (#36)
  userStatus       String      @default("new") // new, interesting, in_progress, rejected
  rating           Int?        // Оценка пользователя 1-5
  isFavorite       Boolean     @default(false)
  isArchived       Boolean     @default(false)
  createdAt        DateTime    @default(now())

  @@index([reportId])
}

// Подписчики на лист ожидания (#37)
model WaitlistEntry {
  id        String   @id @default(cuid())
  ideaId    String
  email     String
  name      String?
  createdAt DateTime @default(now())

  @@index([ideaId])
  @@unique([ideaId, email])
}

// Метрики после запуска (#38)
model IdeaMetric {
  id        String   @id @default(cuid())
  ideaId    String
  name      String   // "visitors", "signups", "revenue", "conversion"
  value     Float
  date      DateTime @default(now())

  @@index([ideaId, name])
}

// Глобальные настройки (одна запись с id="main")
model Settings {
  id                String @id @default("main")
  anthropicApiKey   String?
  newsApiKey        String?
  wordstatToken     String? // OAuth-токен Яндекс Вордстат
  googleTrendsGeo   String @default("RU")
  maxIdeasPerReport Int    @default(10)
  preferredModel    String @default("claude-haiku-4-5-20251001")
  telegramBotToken  String? // Токен Telegram-бота
  telegramChatId    String? // Chat ID для уведомлений
  dadataApiKey      String? // API-ключ DaData для валидации ниши
  vkServiceToken    String? // Сервисный токен VK для трендов ВКонтакте
  siteUrl           String? // Публичный URL сервиса (для ссылок в Telegram)
  // Этап 8: цепочка экспертов + автоматизация
  expertModel          String?                    // Отдельная модель для экспертов (#42)
  scheduleEnabled      Boolean @default(false)    // Включить автогенерацию по расписанию (#40)
  scheduleTime         String  @default("08:00")  // Время генерации HH:MM (#40)
  scheduleAutoTelegram Boolean @default(false)    // Автоотправка в Telegram после генерации (#40)
  // Пресеты фокуса генерации
  focusPresets         String  @default("[]")     // JSON-массив: ["marketplace","telegram"] (макс 3)
}
